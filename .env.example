# Public site URL used by metadata, sitemap and robots.
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Optional Supabase public client variables.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional analytics and monetization IDs.
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_ADSENSE_ID=

# Optional payment public key.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Server-only API keys. Do not expose these with NEXT_PUBLIC_.
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
PERPLEXITY_API_KEY=
